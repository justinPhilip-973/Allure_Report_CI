[
  {
    "name": "Flaky tests",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*(timeout|stale element|connection reset).*",
    "flaky": true
  },
  {
    "name": "Known Issues",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*KNOWN_ISSUE.*"
  },
  {
    "name": "Risk Accepted",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*RISK_ACCEPTED.*"
  },
  {
    "name": "Test defects (broken)",
    "matchedStatuses": ["broken"]
  },
  {
    "name": "Product defects (failed)",
    "matchedStatuses": ["failed"]
  }
]